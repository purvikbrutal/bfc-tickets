
# Client-safe values

# Public site URL used for metadata, ticket links, and email links.
NEXT_PUBLIC_SITE_URL=https://www.brutalfightclub.com

# Razorpay checkout public key exposed to the browser.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Public Google Maps embed URL for the venue section.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=

# Public Google Maps directions URL for the venue CTA.
NEXT_PUBLIC_VENUE_DIRECTIONS_URL=

# Server-only values

# Postgres connection string for bookings and ticket storage.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bfc_event

# Razorpay key ID used by the server when creating orders.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Razorpay secret key used for server-side order creation and signature verification.
RAZORPAY_KEY_SECRET=xxxxxxxxxx

# Razorpay webhook signing secret from the dashboard.
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Resend API key for transactional ticket emails.
RESEND_API_KEY=re_xxxxxxxxxx

# Verified sender identity for Resend, for example "BFC Tickets <tickets@example.com>".
EMAIL_FROM=BFC Tickets <tickets@example.com>

# Google Sheets spreadsheet ID where confirmed tickets are mirrored.
GOOGLE_SHEETS_SPREADSHEET_ID=

# Worksheet/tab name inside the spreadsheet, for example "Bookings".
GOOGLE_SHEETS_SHEET_NAME=Bookings

# Service account client email from the Google Cloud JSON key.
GOOGLE_SERVICE_ACCOUNT_EMAIL=GOOGLE_SERVICE_ACCOUNT_EMAIL=bfc-sheets@xxx.iam.gserviceaccount.com

# Private key from the Google Cloud JSON key. Keep newline characters escaped as \n in env UIs.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Twilio Account SID for optional WhatsApp confirmations.
TWILIO_ACCOUNT_SID=

# Twilio auth token paired with the account SID.
TWILIO_AUTH_TOKEN=

# Twilio WhatsApp sender, for example whatsapp:+14155238886.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin dashboard passcode — protects /admin/dashboard.
ADMIN_PASSCODE=change_me_before_deploy
